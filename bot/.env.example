# ─────────────────────────────────────────────────────────────────────────────
#  Stock Signal Bot – Variáveis de Ambiente
#  Copiar para .env e preencher com os valores reais
# ─────────────────────────────────────────────────────────────────────────────

# Telegram Bot Token (obter via @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ID do chat ou canal Telegram para receber os sinais
# Para obter o ID: enviar mensagem ao bot e aceder a
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your_chat_id_here

# Lista de tickers a monitorizar (separados por vírgula)
# Suporta qualquer ticker do Yahoo Finance (US, PT, EU, etc.)
# Exemplos: AAPL,MSFT,NVDA,TSLA,AMZN,GOOGL,META,AMD
#           EDP.LS,GALP.LS,BCP.LS  (bolsa portuguesa)
#           ASML.AS,SAP.DE          (bolsa europeia)
SYMBOLS=AAPL,MSFT,NVDA,TSLA,AMZN,GOOGL,META,AMD,AVGO,NFLX,ADBE,CSCO,INTC,ORCL,CRM,QCOM,TXN,AMAT,MU,ISRG,PANW,LRCX,HON,SBUX,VRTX,REGN,ADI,KLAC,MDLZ,PYPL,V,MA,JPM,UNH,LLY,XOM,HD,PG,JNJ,ABBV,WMT,COST,BAC,KO,MRK,CVX,PEP,TMO,PFE,LIN,DIS,ACN,ABT,DHR,VZ,NEE,WFC,PM,NKE,RTX,LOW,BMY,COP,UNP,AMGN,T,GE,AXP,MS,GS,CAT,EDP.LS,GALP.LS,BCP.LS,JMT.LS,EDPR.LS,NOS.LS,SON.LS,CTT.LS,RENE.LS,NVG.LS,ALTR.LS,SEM.LS,COR.LS,EGL.LS,IBS.LS,NBA.LS,PHR.LS

# Diretório para ficheiros de persistência (stats e trades)
# Por defeito: /tmp (não persiste entre reinícios)
# Para persistência: usar um diretório local, ex: ./data
DATA_DIR=/tmp
